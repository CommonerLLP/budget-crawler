lmmha:5475-00-101 a skos:Concept ;
    dct:identifier "5475-00-101" ;
    dct:source "LMMHA note 1, part4c.htm"@en,
        "LMMHA note 3, part4c.htm"@en ;
    dct:type "Minor Head"@en ;
    skos:broader lmmha:5475 ;
    skos:inScheme lmmha:scheme ;
    skos:prefLabel "Land Ceilings (other than agricultural land)"@en ;
    skos:scopeNote "Compensation Bonds issued under Land ceiling laws will be accounted for under this head."@en,
        "In case where Bonds are issued in lieu of cash paymen ts the value of the bonds is debited to this head by per contra credit to the head '6001-Intemal Debt of the Central Government-compensation and other Bonds'/'6003 Internal Debt of the State Government-compensation and other Bonds' as the case may be in the sector 'Public Debt'."@en .

lmmha:5475-00-102 a skos:Concept ;
    dct:identifier "5475-00-102" ;
