    dct:type "Minor Head"@en ;
    skos:broader lmmha:5475 ;
    skos:inScheme lmmha:scheme ;
    skos:prefLabel "Civil Supplies"@en ;
    skos:scopeNote "Please see Note (1 ) below the Major Head '4408 Capital Outlay on Food, Storage and Warehousing'. This minor head will record expenditure on civil supply schemes other than those relating to food grains and pulses such as on procurement and distribution of Vanaspati, Edible Oils, Kerosene etc."@en .

lmmha:5475-00-103 a skos:Concept ;
    dct:identifier "5475-00-103" ;
    dct:source "LMMHA note 1, part4c.htm"@en,
        "LMMHA note 3, part4c.htm"@en ;
