    skos:inScheme lmmha:scheme ;
    skos:prefLabel "Entertainment Expenses"@en .

lmmha:2012-01-107 a skos:Concept ;
    dct:identifier "2012-01-107" ;
    dct:source "LMMHA note 3, part2.htm"@en ;
    dct:type "Minor Head"@en ;
    skos:broader lmmha:2012-01 ;
    skos:inScheme lmmha:scheme ;
    skos:prefLabel "Expenditure from Contract Allowance"@en ;
    skos:scopeNote "These heads are meant for expenditure of a semi-private character such as stable establishments and contingencies, wages and allowances of household servants, etc., incurred by the President and the Governors, which is met from the contract grant. Charges on account of maintenance of State motor cars are also debited to this head, in the sub-major head\"03\"."@en .

