lmmha:2020 a skos:Concept ;
    dct:identifier "2020" ;
    dct:source "LMMHA note 1, part2.htm"@en ;
    dct:type "Major Head"@en ;
    skos:inScheme lmmha:scheme ;
    skos:narrower lmmha:2020-00-001,
        lmmha:2020-00-101,
        lmmha:2020-00-102,
