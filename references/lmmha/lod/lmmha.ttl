lmmha:8443-00-102 a skos:Concept ;
    dct:identifier "8443-00-102" ;
    dct:source "LMMHA note 2, part4i.htm"@en ;
    dct:type "Minor Head"@en ;
    skos:broader lmmha:8443 ;
    skos:inScheme lmmha:scheme ;
    skos:prefLabel "Customs and opium Deposits"@en ;
    skos:scopeNote "These will appear as deposits of the Central Government in the books of several Principal Account Officers of Ministries/Departments."@en .

lmmha:8443-00-103 a skos:Concept ;
    dct:identifier "8443-00-103" ;
    dct:source "LMMHA note 3, part4i.htm"@en ;
    dct:type "Minor Head"@en ;
    skos:broader lmmha:8443 ;
    skos:inScheme lmmha:scheme ;
    skos:prefLabel "Security Deposits"@en ;
    skos:scopeNote "These will include earnest money deposits made by intending tenderers of the Civil Defence Departments, and Security Deposits realised by the Police Department under the Motor Vehicles Tax Act or other Acts. In the case of earnest money deposits of intending tenderers of the P.W.D., these relating to successful tenderers, where the Departmental officers of the P.W.D. desire that these deposits should be transferred to the credit of the P.W. Department as security deposit of contractors, they may be transferred to the minor head \"P.W.D. deposits' in terms of 188 of Central Government Accounts (R & P) Rules 1983. This head also includes cash security deposits realised under the financial rules of the Government and Security Deposits under Emigration Rules, 1983. Cash security deposits of subordinates of the P.W.D. realised in public works divisions will, however, be credited under the minor head 'public works deposits'."@en .

lmmha:8443-00-104 a skos:Concept ;
    dct:identifier "8443-00-104" ;
    dct:source "LMMHA note 4, part4i.htm"@en ;
    dct:type "Minor Head"@en ;
    skos:broader lmmha:8443 ;
    skos:inScheme lmmha:scheme ;
    skos:prefLabel "Civil Courts Deposits"@en ;
    skos:scopeNote "Under Civil Court Deposits, Supreme Court, High Courts, Small Causes Courts and Income-tax Officers who receive such deposits may be distinguished in inner columns."@en .

lmmha:8443-00-105 a skos:Concept ;
    dct:identifier "8443-00-105" ;
    dct:type "Minor Head"@en ;
    skos:broader lmmha:8443 ;
    skos:inScheme lmmha:scheme ;
    skos:prefLabel "Criminal Courts Deposits"@en .

lmmha:8443-00-106 a skos:Concept ;
    dct:identifier "8443-00-106" ;
    dct:source "LMMHA note 5, part4i.htm"@en ;
    dct:type "Minor Head"@en ;
    skos:broader lmmha:8443 ;
    skos:inScheme lmmha:scheme ;
    skos:prefLabel "Personal Deposits"@en ;
    skos:scopeNote "'Personal Deposits' are deposits of which a banking account only is kept (not being Civil or Criminal Court Deposits). Details such as \"Wards\" and \"Attached Estates Deposits\" and \"Trusts and Endowments\" may be kept in the local accounts."@en .

lmmha:8443-00-107 a skos:Concept ;
    dct:identifier "8443-00-107" ;
    dct:source "LMMHA note 6, part4i.htm"@en ;
    dct:type "Minor Head"@en ;
    skos:broader lmmha:8443 ;
    skos:inScheme lmmha:scheme ;
    skos:prefLabel "Trust Interest Funds"@en ;
    skos:scopeNote "This head is intended as a \"Personal Deposit\" for accommodating receipt on account of interest on the securities held by the Accountants General and other Government Officers acting as Treasurers of Charitable Endowments under the Charitable Endowments Act, and also for making payment of arrears of interest etc. from out of the accretions and balances lying at the credit of this head."@en .

lmmha:8443-00-108 a skos:Concept ;
    dct:identifier "8443-00-108" ;
    dct:type "Minor Head"@en ;
