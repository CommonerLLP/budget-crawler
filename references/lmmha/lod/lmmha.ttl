    skos:broader lmmha:8443 ;
    skos:inScheme lmmha:scheme ;
    skos:prefLabel "Other Departmental Deposits"@en .

lmmha:8443-00-112 a skos:Concept ;
    dct:identifier "8443-00-112" ;
    dct:source "LMMHA note 7, part4i.htm"@en ;
    dct:type "Minor Head"@en ;
    skos:broader lmmha:8443 ;
    skos:inScheme lmmha:scheme ;
    skos:prefLabel "Deposits for purchases etc. in India"@en ;
    skos:scopeNote "This head is intended to record inter-alia the deposits received from Municipalities and other outside bodies etc., on account of value of stores purchased by them through the Director General of Supplies and Disposals of Government of India or other Central stores purchases organisations etc. in the State Government"@en .

lmmha:8443-00-113 a skos:Concept ;
    dct:identifier "8443-00-113" ;
    dct:source "LMMHA note 8, part4i.htm"@en ;
    dct:type "Minor Head"@en ;
    skos:broader lmmha:8443 ;
    skos:inScheme lmmha:scheme ;
    skos:prefLabel "Deposits for purchases etc, abroad"@en ;
    skos:scopeNote "Amounts deposited in respect of purchase and procurements under foreign Credit/Loan agreements are adjusted under a sub-head \"Purchases under Credit/Loan agreements\", while those relating to other purchase and procurements, viz. through the I.S.M. etc. are taken to a sub-head \"Other purchases.\" Suitable detailed heads may be opened for each Credit/Loan agreements wherever necessary. Another sub-head \"Miscellaneous\" is intended to account for the rupee deposits made by the State Electricity Boards on account of inspection charges."@en .

lmmha:8443-00-114 a skos:Concept ;
    dct:identifier "8443-00-114" ;
    dct:type "Minor Head"@en ;
    skos:broader lmmha:8443 ;
    skos:inScheme lmmha:scheme ;
    skos:prefLabel "Export Trade Deposits"@en .

lmmha:8443-00-115 a skos:Concept ;
    dct:identifier "8443-00-115" ;
    dct:type "Minor Head"@en ;
    skos:broader lmmha:8443 ;
    skos:inScheme lmmha:scheme ;
    skos:prefLabel "Deposits received by Government Commercial Undertakings"@en .

lmmha:8443-00-116 a skos:Concept ;
    dct:identifier "8443-00-116" ;
    dct:source "LMMHA note 9, part4i.htm"@en ;
    dct:type "Minor Head"@en ;
    skos:broader lmmha:8443 ;
    skos:inScheme lmmha:scheme ;
    skos:prefLabel "Deposits under various Central and State Acts"@en ;
    skos:scopeNote "Deposits in respect of each\" Act\" may be shown under a distinct sub-head, such as \"Deposits under Section 22-D of Minimum Wages Act, 1948\", \"Deposits under the Contract Labour (Regulations and Abolition) Act, 1970\", \"Deposits of the surplus estates of deceased officers, deserters and others of the Indian Army\", \"Deposits under the Bombay Public Conveyance Act\", etc."@en .

lmmha:8443-00-117 a skos:Concept ;
    dct:identifier "8443-00-117" ;
    dct:source "LMMHA note 10, part4i.htm"@en ;
    dct:type "Minor Head"@en ;
    skos:broader lmmha:8443 ;
    skos:inScheme lmmha:scheme ;
    skos:prefLabel "Deposits for work done for Public bodies or private individuals"@en ;
    skos:scopeNote "Sums received in advance from Municipalities or other bodies financially independent of Government for payment of compensation for land acquired for such bodies are credited to this head. Fees deposited by the Indian Nationals for procurement of Educational Certificates etc. for them from the Bangladesh authorities (Through Indian High Commission in Bangladesh) will also be recorded under this minor head."@en .

lmmha:8443-00-118 a skos:Concept ;
    dct:identifier "8443-00-118" ;
    dct:type "Minor Head"@en ;
    skos:broader lmmha:8443 ;
    skos:inScheme lmmha:scheme ;
    skos:prefLabel "Deposits of fees received by Government servants for work done for private bodies."@en .

