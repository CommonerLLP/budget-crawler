lmmha:5475-00-202 a skos:Concept ;
    dct:identifier "5475-00-202" ;
    dct:source "LMMHA note 2, part4c.htm"@en,
        "LMMHA note 3, part4c.htm"@en ;
    dct:type "Minor Head"@en ;
    skos:broader lmmha:5475 ;
    skos:inScheme lmmha:scheme ;
    skos:prefLabel "Compensation to Land holders on abolition of Zamindari System"@en ;
    skos:scopeNote "In case where Bonds are issued in lieu of cash paymen ts the value of the bonds is debited to this head by per contra credit to the head '6001-Intemal Debt of the Central Government-compensation and other Bonds'/'6003 Internal Debt of the State Government-compensation and other Bonds' as the case may be in the sector 'Public Debt'."@en,
        "This head will record payments of compensation to Landholders on the abolition of Zamindari system, when it is decided to capitalise the expenditure."@en .

